// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            String         @id @default(uuid())
  name          String
  nit           String         @unique
  address       String?
  createdAt     DateTime       @default(now())
  users         User[]
  residents     Resident[]
  properties    Property[]
  vehicles      Vehicle[]
  wallets       Wallet[]
  pqrs          Pqrs[]
  bookings      Booking[]
  packages      Package[]
  visitors      Visitor[]
  announcements Announcement[]
  minutes       Minutes[]
  notifications Notification[]
  auditLogs     AuditLog[]
  payments      Payment[]
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  password              String
  firstName             String
  lastName              String
  role                  String // SUPERADMIN, ADMINISTRADOR, PORTERÍA, RESIDENTE, CONTABILIDAD, CONSEJO
  tenantId              String? // Nullable only for SUPERADMIN
  tenant                Tenant?        @relation(fields: [tenantId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  auditLogs             AuditLog[]
  sentNotifications     Notification[] @relation("SentNotifications")
  receivedNotifications Notification[] @relation("ReceivedNotifications")
}

model Resident {
  id         String             @id @default(uuid())
  firstName  String
  lastName   String
  document   String
  email      String
  phone      String?
  status     String             @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  properties PropertyResident[]
  vehicles   Vehicle[]
  bookings   Booking[]
  packages   Package[]
  visitors   Visitor[]          @relation("ResidentVisitor")
}

model Owner {
  id         String     @id @default(uuid())
  firstName  String
  lastName   String
  document   String
  email      String
  phone      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model Property {
  id          String             @id @default(uuid())
  tower       String
  unit        String
  type        String // apartamento, casa, local, oficina
  area        Float
  coefficient Float
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  ownerId     String?
  owner       Owner?             @relation(fields: [ownerId], references: [id])
  residents   PropertyResident[]
  vehicles    Vehicle[]
  wallet      Wallet?
  packages    Package[]
  visitors    Visitor[]
  pqrs        Pqrs[]
}

model PropertyResident {
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id])
  isPrimary  Boolean  @default(true)
  type       String   @default("TENANT") // OWNER_OCCUPANT, TENANT

  @@id([propertyId, residentId])
}

model Vehicle {
  id         String    @id @default(uuid())
  plate      String
  type       String // carro, moto, etc
  brand      String?
  model      String?
  color      String?
  createdAt  DateTime  @default(now())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id])
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
}

model Wallet {
  id         String    @id @default(uuid())
  balance    Float     @default(0.0)
  propertyId String    @unique
  property   Property  @relation(fields: [propertyId], references: [id])
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  payments   Payment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Payment {
  id         String   @id @default(uuid())
  amount     Float
  method     String // CASH, TRANSFER, PSE
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  attachment String?
  walletId   String
  wallet     Wallet   @relation(fields: [walletId], references: [id])
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Pqrs {
  id          String    @id @default(uuid())
  subject     String
  description String
  category    String // ruido, mascotas, parqueaderos, administración, seguridad, otros
  status      String    @default("nueva") // nueva, asignada, proceso, resuelta, cerrada
  attachment  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
}

model Booking {
  id         String   @id @default(uuid())
  area       String // salón social, BBQ, cancha, gimnasio, piscina
  startTime  DateTime
  endTime    DateTime
  status     String   @default("PENDING") // PENDING, APPROVED, CANCELLED
  createdAt  DateTime @default(now())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id])
}

model Package {
  id             String    @id @default(uuid())
  trackingNumber String?
  courier        String
  photoUrl       String?
  status         String    @default("recibido") // recibido, notificado, entregado
  receivedAt     DateTime  @default(now())
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  propertyId     String
  property       Property  @relation(fields: [propertyId], references: [id])
  residentId     String?
  resident       Resident? @relation(fields: [residentId], references: [id])
}

model Visitor {
  id         String    @id @default(uuid())
  name       String
  document   String?
  plate      String?
  authorized Boolean   @default(true)
  qrCode     String?
  createdAt  DateTime  @default(now())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])
  residentId String?
  resident   Resident? @relation("ResidentVisitor", fields: [residentId], references: [id])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String // general, torre, grupo específico
  channels  String // correo, push, panel interno
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Minutes {
  id          String   @id @default(uuid())
  title       String
  content     String
  meetingDate DateTime
  createdAt   DateTime @default(now())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  title      String
  body       String
  type       String // visitante, paquete, pqrs, reserva, pago
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  senderId   String?
  sender     User?    @relation("SentNotifications", fields: [senderId], references: [id])
  receiverId String?
  receiver   User?    @relation("ReceivedNotifications", fields: [receiverId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  ipAddress String?
  module    String
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}
